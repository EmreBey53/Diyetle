rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Patients collection
    match /patients/{patientId} {
      allow read, write: if request.auth != null;
    }
    
    // Diet plans collection
    match /dietPlans/{planId} {
      allow read, write: if request.auth != null;
    }
    
    // Progress collection
    match /progress/{progressId} {
      allow read, write: if request.auth != null;
    }
    
    // Questions collection
    match /questions/{questionId} {
      allow read, write: if request.auth != null;
    }
    
    // Chat rooms collection
    match /chat_rooms/{roomId} {
      allow read, write: if request.auth != null;
    }
    
    // Chat messages collection
    match /chat_messages/{messageId} {
      allow read, write: if request.auth != null;
    }
    
    // Video calls collection
    match /video_calls/{callId} {
      allow read, write: if request.auth != null;
    }
    
    // Video appointments collection
    match /video_appointments/{appointmentId} {
      allow read, write: if request.auth != null;
    }
    
    // Appointment slots collection
    match /appointment_slots/{slotId} {
      allow read, write: if request.auth != null;
    }
    
    // Call sessions collection
    match /call_sessions/{sessionId} {
      allow read, write: if request.auth != null;
    }
    
    // Audit logs collection
    match /audit_logs/{logId} {
      allow read, write: if request.auth != null;
    }
    
    // KVKK consents collection
    match /kvkk_consents/{consentId} {
      allow read, write: if request.auth != null && request.auth.uid == consentId;
    }
    
    // Smart notifications collection
    match /smart_notifications/{notificationId} {
      allow read, write: if request.auth != null;
    }
    
    // Push tokens collection
    match /push_tokens/{tokenId} {
      allow read, write: if request.auth != null;
    }
    
    // Achievements collection
    match /achievements/{achievementId} {
      allow read, write: if request.auth != null;
    }
    
    // Data portability requests collection
    match /data_portability_requests/{requestId} {
      allow read, write: if request.auth != null && request.auth.uid == requestId;
    }
    
    // Appointment reminders collection
    match /appointment_reminders/{reminderId} {
      allow read, write: if request.auth != null;
    }
    
    // Challenges collection
    match /challenges/{challengeId} {
      allow read, write: if request.auth != null;
    }
  }
}